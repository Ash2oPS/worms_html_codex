{
  "name": "worms_html_codex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "serve": "serve dist -s -l tcp://127.0.0.1:41783 --no-clipboard",
    "serve:build": "npm run build && npm run serve",
    "qa": "npm run qa:smoke",
    "qa:install-browsers": "playwright install chromium",
    "qa:smoke": "node scripts/qa/run_with_static_server.mjs scripts/qa/smoke_hooks.mjs",
    "qa:ai": "node scripts/qa/run_with_static_server.mjs scripts/qa/ai_batch_eval.mjs 8 420",
    "qa:backjump": "node scripts/qa/run_with_static_server.mjs scripts/qa/backjump_probe.mjs 4",
    "qa:double-jump": "node scripts/qa/run_with_static_server.mjs scripts/qa/double_jump_manual_probe.mjs",
    "qa:double-jump:capture": "node scripts/qa/run_with_static_server.mjs scripts/qa/double_jump_manual_capture.mjs",
    "verify": "npm run build && node scripts/qa/run_with_static_server.mjs scripts/qa/smoke_hooks.mjs"
  },
  "devDependencies": {
    "playwright": "^1.53.2",
    "serve": "^14.2.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@dimforge/rapier2d": "^0.19.3",
    "pixi.js": "^8.17.1"
  }
}
